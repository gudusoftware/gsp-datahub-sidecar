# gsp-datahub-sidecar configuration
#
# Four backend modes — uncomment the one you need:
#
#   anonymous   : No signup needed. 50 calls/day per IP. Good for evaluation.
#   authenticated: userId + secretKey on api.gudusoft.com. 10k calls/month.
#                  Sign up at https://docs.gudusoft.com/sign-up/
#   self_hosted : Your own SQLFlow Docker. Unlimited. Data stays in your VPC.
#   local_jar   : Invoke a licensed gsqlparser-*-shaded.jar directly via
#                 subprocess. No network, no Docker — SQL never leaves the
#                 process. Requires a JRE (8+) and a JAR you're licensed to
#                 run; the sidecar does NOT bundle the SQLFlow JAR.
#
# `authenticated` and `self_hosted` use the same SQLFlow token-exchange
# protocol (userId + secretKey -> JWT -> lineage call) — only the host differs.
# `local_jar` skips HTTP entirely and calls DataFlowAnalyzer's CLI.
#
# All settings can be overridden with environment variables:
#   GSP_BACKEND_MODE, GSP_SQLFLOW_URL, GSP_SQLFLOW_USER_ID, GSP_SQLFLOW_SECRET_KEY,
#   GSP_DATAHUB_SERVER, GSP_DATAHUB_TOKEN, GSP_DB_VENDOR,
#   GSP_JAR_PATH, GSP_JAVA_BIN

# ---------------------------------------------------------------------------
# SQLFlow backend
# ---------------------------------------------------------------------------
sqlflow:
  # Backend mode: anonymous | authenticated | self_hosted | local_jar
  mode: anonymous

  # Override the SQLFlow API URL (optional — each mode has a sensible default).
  # Defaults:
  #   anonymous     -> https://api.gudusoft.com/gspLive_backend/api/anonymous/lineage
  #   authenticated -> https://api.gudusoft.com/gspLive_backend/sqlflow/generation/sqlflow/exportFullLineageAsJson
  #   self_hosted   -> http://localhost:8165/api/gspLive_backend/sqlflow/generation/sqlflow/exportFullLineageAsJson
  # Set only when your SQLFlow Docker is not on localhost:8165, e.g.:
  # url: http://sqlflow.internal:9100/api/gspLive_backend/sqlflow/generation/sqlflow/exportFullLineageAsJson

  # For "authenticated" and "self_hosted" modes: your userId + secretKey.
  # Get them from https://docs.gudusoft.com/sign-up/ (cloud) or from the
  # SQLFlow web UI of your Docker at http://<host>:8165/ (self-hosted).
  # user_id: your-user-id
  # secret_key: your-secret-key

  # Default SQL dialect for lineage analysis
  db_vendor: dbvbigquery

  # Relation types to request (comma-separated: fdd, fdr, join, call, er)
  show_relation_type: fdd

  # --- local_jar mode only ---
  # Absolute path to a licensed gsqlparser-*-shaded.jar. Required when
  # mode: local_jar. The sidecar does not bundle this JAR — supply your own.
  # jar_path: /path/to/your/gsqlparser-4.1.0.13-shaded.jar
  #
  # Java executable. Defaults to 'java' on PATH; set if you need a specific JDK.
  # java_bin: java

# ---------------------------------------------------------------------------
# DataHub connection
# ---------------------------------------------------------------------------
datahub:
  # DataHub GMS server URL
  server: http://localhost:8080

  # DataHub auth token (if authentication is enabled)
  # token: eyJhbGciOi...

  # DataHub platform name (used in dataset URN construction)
  platform: bigquery

  # DataHub environment (PROD, DEV, STAGING)
  env: PROD

  # Emit column-level (fine-grained) lineage alongside table-level.
  # Set to false to emit table-only lineage (e.g. to A/B test against a
  # table-only baseline). Default: true.
  # column_lineage: true

# ---------------------------------------------------------------------------
# Log parsing
# ---------------------------------------------------------------------------
log_parser:
  # Path to DataHub ingestion log file
  # log_file: /var/log/datahub/ingest.log

  # Or: provide SQL files/statements directly (bypass log parsing)
  # sql_file: /path/to/queries.sql
  # sql_text: "SELECT a FROM t"
