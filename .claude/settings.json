{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-push-tests.sh",
            "timeout": 300,
            "statusMessage": "Running pytest before pushing to main/master..."
          }
        ]
      }
    ]
  }
}
